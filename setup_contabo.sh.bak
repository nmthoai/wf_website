#!/bin/bash
# setup_contabo.sh - Automated Deployment Script for Contabo VPS
# Author: Antigravity AI
# Usage: sudo bash setup_contabo.sh

set -e

echo "=========================================================="
echo " Starting Contabo VPS Environment Setup (WorkFactory)     "
echo "=========================================================="

# 1. Update & Install Docker
echo "[1/4] Installing Docker Engine..."
apt-get update
apt-get install -y ca-certificates curl gnupg lsb-release
mkdir -p /etc/apt/keyrings
curl -fsSL https://download.docker.com/linux/ubuntu/gpg | gpg --dearmor -o /etc/apt/keyrings/docker.gpg
echo \
  "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu \
  $(lsb_release -cs) stable" | tee /etc/apt/sources.list.d/docker.list > /dev/null
apt-get update
apt-get install -y docker-ce docker-ce-cli containerd.io docker-compose-plugin

# 2. Install Nginx & Certbot for SSL
echo "[2/4] Installing Nginx and Certbot..."
apt-get install -y nginx certbot python3-certbot-nginx

# 3. Create Nginx Configuration
echo "[3/4] Configuring Nginx Reverse Proxy..."
DOMAIN="workfactory.ai" # Replace with your domain if different
NGINX_CONF="/etc/nginx/sites-available/wf-website"

cat > $NGINX_CONF <<EOF
server {
    listen 80;
    server_name $DOMAIN www.$DOMAIN;

    location / {
        proxy_pass http://localhost:8080;
        proxy_http_version 1.1;
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host \$host;
        proxy_cache_bypass \$http_upgrade;
    }
}
EOF

ln -sf $NGINX_CONF /etc/nginx/sites-enabled/
rm -f /etc/nginx/sites-enabled/default
nginx -t
systemctl restart nginx

# 4. Final Instructions
echo "=========================================================="
echo " Setup Preparation Complete!                              "
echo "=========================================================="
echo " FINAL STEPS FOR THE USER:"
echo " 1. Update your Domain DNS A Record to point to this VPS IP."
echo " 2. Run: sudo certbot --nginx -d $DOMAIN -d www.$DOMAIN"
echo " 3. Upload your project files (wf_website) to this server."
echo " 4. Run: sudo docker compose up -d --build"
echo "=========================================================="
